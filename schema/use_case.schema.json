{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DCM Use Case",
  "type": "object",
  "required": [
    "uuid",
    "handle",
    "version",
    "scenario",
    "generated_by"
  ],
  "properties": {
    "uuid": {
      "type": "string",
      "pattern": "^uc-"
    },
    "handle": {
      "type": "string",
      "pattern": ".*/.*"
    },
    "version": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scenario": {
      "type": "object",
      "required": [
        "description",
        "actor",
        "intent",
        "success_criteria",
        "dimensions",
        "profile"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "actor": {
          "type": "object",
          "required": [
            "persona",
            "profile"
          ],
          "properties": {
            "persona": {
              "type": "string"
            },
            "profile": {
              "enum": [
                "minimal",
                "dev",
                "standard",
                "prod",
                "fsi",
                "sovereign"
              ]
            }
          }
        },
        "intent": {
          "type": "string"
        },
        "success_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "dimensions": {
          "type": "object",
          "required": [
            "lifecycle_phase",
            "resource_complexity",
            "policy_complexity",
            "provider_landscape",
            "governance_context",
            "failure_mode"
          ],
          "properties": {
            "lifecycle_phase": {
              "type": "string"
            },
            "resource_complexity": {
              "type": "string"
            },
            "policy_complexity": {
              "type": "string"
            },
            "provider_landscape": {
              "type": "string"
            },
            "governance_context": {
              "type": "string"
            },
            "failure_mode": {
              "type": "string"
            }
          }
        },
        "profile": {
          "enum": [
            "minimal",
            "dev",
            "standard",
            "prod",
            "fsi",
            "sovereign"
          ]
        },
        "expected_domain_interactions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "domain",
              "interaction"
            ],
            "properties": {
              "domain": {
                "type": "string"
              },
              "interaction": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "generated_by": {
      "type": "object",
      "required": [
        "mode",
        "source"
      ],
      "properties": {
        "mode": {
          "enum": [
            "regression",
            "pr-targeted",
            "authoring"
          ]
        },
        "source": {
          "enum": [
            "corpus",
            "llm-unguided",
            "llm-guided",
            "human-authored"
          ]
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        },
        "prompt_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "timestamp": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}